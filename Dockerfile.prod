# 简单的生产环境Dockerfile

# 构建阶段
FROM golang:1.21-alpine AS builder
WORKDIR /app
COPY go.* ./
RUN go mod download
COPY . .
RUN go build -ldflags="-s -w" -o Yearning .

# 运行阶段
FROM alpine:latest
RUN apk --no-cache add ca-certificates tzdata
WORKDIR /app
COPY --from=builder /app/Yearning .
COPY conf.toml.template conf.toml.template
EXPOSE 8000
CMD ["./Yearning", "run"]
