# 前端开发环境Dockerfile - 使用官方Yearning-gemini
FROM node:16-alpine

# 安装开发工具
RUN apk add --no-cache git bash curl

# 设置工作目录
WORKDIR /app

# 克隆官方前端仓库
RUN git clone https://github.com/cookieY/Yearning-gemini.git .

# 设置npm镜像源
RUN npm config set registry https://registry.npmmirror.com

RUN npm install

# 修改开发服务器配置为5001端口
RUN if [ -f "vue.config.js" ]; then \
    sed -i "s/port: [0-9]*/port: 5001/g" vue.config.js; \
    fi

# 如果有vite.config.js，也需要修改
RUN if [ -f "vite.config.js" ]; then \
    sed -i "s/port: [0-9]*/port: 5001/g" vite.config.js; \
    fi

# 创建或修改API代理配置
RUN cat > /app/proxy.config.js << 'EOF'
module.exports = {
  devServer: {
    port: 5001,
    proxy: {
      '/api': {
        target: 'http://backend-dev:8000',
        changeOrigin: true,
        secure: false
      },
      '/login': {
        target: 'http://backend-dev:8000',
        changeOrigin: true
      },
      '/register': {
        target: 'http://backend-dev:8000',
        changeOrigin: true
      }
    }
  }
}
EOF

EXPOSE 5001

# 使用官方前端的启动命令
CMD ["npm", "run", "serve"]
