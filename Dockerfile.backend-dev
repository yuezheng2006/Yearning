# 后端开发环境Dockerfile
FROM golang:1.21-alpine AS dev

# 安装开发工具
RUN apk add --no-cache \
    git \
    bash \
    curl \
    make \
    gcc \
    musl-dev \
    && go install github.com/go-delve/delve/cmd/dlv@latest \
    && go install github.com/air-verse/air@latest

# 设置工作目录
WORKDIR /app

# 复制go mod文件
COPY go.mod go.sum ./

# 下载依赖
RUN go mod download

# 复制源代码
COPY . .

# 创建配置文件
RUN cp conf.toml.template conf.toml

# 设置环境变量
ENV CGO_ENABLED=1
ENV GOOS=linux
ENV GOPATH=/go
ENV PATH=$GOPATH/bin:$PATH

# 创建开发启动脚本
RUN cat > /app/dev-start.sh << 'EOF'
#!/bin/bash

# 更新配置文件
if [ ! -z "$MYSQL_ADDR" ]; then
    sed -i "s/Host = \"127.0.0.1\"/Host = \"$MYSQL_ADDR\"/" conf.toml
fi
if [ ! -z "$MYSQL_PORT" ]; then
    sed -i "s/Port = \"3306\"/Port = \"$MYSQL_PORT\"/" conf.toml
fi
if [ ! -z "$MYSQL_USER" ]; then
    sed -i "s/User = \"root\"/User = \"$MYSQL_USER\"/" conf.toml
fi
if [ ! -z "$MYSQL_PASSWORD" ]; then
    sed -i "s/Password = \"xxxxxxx\"/Password = \"$MYSQL_PASSWORD\"/" conf.toml
fi
if [ ! -z "$MYSQL_DB" ]; then
    sed -i "s/Db = \"Yearning_go\"/Db = \"$MYSQL_DB\"/" conf.toml
fi
if [ ! -z "$SECRET_KEY" ]; then
    sed -i "s/SecretKey = \"dbcjqheupqjsuwsm\"/SecretKey = \"$SECRET_KEY\"/" conf.toml
fi
if [ ! -z "$Y_LANG" ]; then
    sed -i "s/Lang = \"en_US\"/Lang = \"$Y_LANG\"/" conf.toml
fi

# 根据参数执行相应操作
case "$1" in
    "install")
        echo "初始化数据库..."
        echo "yes" | go run . install
        ;;
    "debug")
        echo "启动调试模式..."
        dlv debug --headless --listen=:2345 --api-version=2 --accept-multiclient . -- run --port 8000
        ;;
    "run")
        echo "启动开发服务器..."
        go run . run --port 8000
        ;;
    "air")
        echo "启动热重载开发服务器..."
        air
        ;;
    *)
        echo "用法: $0 {install|debug|run|air}"
        exit 1
        ;;
esac
EOF

RUN chmod +x /app/dev-start.sh

# 创建Air配置文件用于热重载
RUN cat > /app/.air.toml << 'EOF'
root = "."
testdata_dir = "testdata"
tmp_dir = "tmp"

[build]
  args_bin = ["run", "--port", "8000"]
  bin = "./tmp/main"
  cmd = "go build -o ./tmp/main ."
  delay = 1000
  exclude_dir = ["assets", "tmp", "vendor", "testdata", "frontend-dev"]
  exclude_file = []
  exclude_regex = ["_test.go"]
  exclude_unchanged = false
  follow_symlink = false
  full_bin = ""
  include_dir = []
  include_ext = ["go", "tpl", "tmpl", "html"]
  include_file = []
  kill_delay = "0s"
  log = "build-errors.log"
  poll = false
  poll_interval = 0
  rerun = false
  rerun_delay = 500
  send_interrupt = false
  stop_on_root = false

[color]
  app = ""
  build = "yellow"
  main = "magenta"
  runner = "green"
  watcher = "cyan"

[log]
  main_only = false
  time = false

[misc]
  clean_on_exit = false

[screen]
  clear_on_rebuild = false
  keep_scroll = true
EOF

EXPOSE 8000 2345

CMD ["/app/dev-start.sh", "debug"]
